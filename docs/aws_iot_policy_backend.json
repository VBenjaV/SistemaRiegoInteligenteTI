{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:sa-east-1:*:client/riego-backend-*"
    },
    {
      "Effect": "Allow",
      "Action": ["iot:Subscribe", "iot:Receive"],
      "Resource": [
        "arn:aws:iot:sa-east-1:*:topicfilter/Esp8266/pub",
        "arn:aws:iot:sa-east-1:*:topicfilter/ESP8266/pub",
        "arn:aws:iot:sa-east-1:*:topicfilter/Esp8266/#",
        "arn:aws:iot:sa-east-1:*:topic/Esp8266/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": [
        "arn:aws:iot:sa-east-1:*:topic/Esp8266/sub",
        "arn:aws:iot:sa-east-1:*:topic/ESP8266/sub"
      ]
    }
  ]
}
