# Backend Configuration
DEBUG=True
API_TITLE=Sistema Riego Inteligente API
API_VERSION=1.0.0

# Supabase Auth (registro/login)
SUPABASE_URL=https://TU_PROYECTO.supabase.co
# anon / publishable (eyJhbGci... o sb_publishable_...) — NO sb_secret_ / service_role
SUPABASE_KEY=your_supabase_anon_public_key

# PostgreSQL pooler (config, riego, clima)
# Pooler sa-east-1 (copiar URI exacta desde Supabase → Database → Connection string)
SUPABASE_DB_URL=postgresql+psycopg2://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# MongoDB (lecturas de sensores desde IoT Core)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=riego_inteligente
MONGODB_COLLECTION_LECTURAS=lecturas_sensores
DISPOSITIVO_DEFAULT_ID=esp8266

# AWS IoT Core
AWS_IOT_ENDPOINT=a319gtmfe1r2jb-ats.iot.sa-east-1.amazonaws.com
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
MQTT_CA_PATH=../IotCore/AmazonRootCA1.pem
MQTT_CERT_PATH=../IotCore/4bb52c4252bfb1b205ea09eb59a655000d689f05c3b72aa689f775caa548496e-certificate.pem.crt
MQTT_KEY_PATH=../IotCore/4bb52c4252bfb1b205ea09eb59a655000d689f05c3b72aa689f775caa548496e-private.pem.key
MQTT_TOPIC_SUBSCRIBE=esp8266/pub
MQTT_TOPIC_PUBLISH=esp8266/sub
MQTT_CLIENT_ID=riego-backend-1

# Weather API
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=Mexico City
WEATHER_UPDATE_INTERVAL_HOURS=1
WEATHER_RAIN_THRESHOLD_MM=5
WEATHER_FORECAST_HOURS=24

# Irrigation Logic
HUMIDITY_THRESHOLD_PERCENT=40
IRRIGATION_DURATION_SECONDS=300
SENSOR_READ_INTERVAL_MINUTES=5

# API
API_HOST=0.0.0.0
API_PORT=8000
